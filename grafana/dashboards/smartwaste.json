    {
      "title": "Category Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT label AS metric, COUNT(*) AS value FROM waste_entries GROUP BY label ORDER BY value DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Classifications Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', timestamp) AS time, label, COUNT(*) AS count FROM waste_entries WHERE $__timeFilter(timestamp) GROUP BY 1, 2 ORDER BY 1;",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Recent Classifications",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "" },
      "targets": [
        {
          "rawSql": "SELECT timestamp, label, description, brand_product, location FROM waste_entries ORDER BY timestamp DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Simulated Environment Sensors",
      "type": "timeseries",
