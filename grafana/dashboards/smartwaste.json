        {
          "rawSql": "SELECT timestamp AS time, simulated_temperature AS temperature, simulated_humidity AS humidity, simulated_air_pollution AS air_pollution FROM waste_entries WHERE $__timeFilter(timestamp) ORDER BY timestamp;",
